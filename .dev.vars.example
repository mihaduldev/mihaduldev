# Local development secrets for `wrangler` / the Cloudflare adapter.
# Copy to `.dev.vars` (gitignored) and fill in. In production set these with
# `wrangler secret put ADMIN_PASSWORD` and `wrangler secret put AUTH_SECRET`.

# The single admin password (no username — just this password to log in).
ADMIN_PASSWORD=change-me

# Long random string used to sign the admin session cookie.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-a-long-random-string

# Cloudflare Web Analytics beacon token (Dashboard → Analytics → Web Analytics).
# Leave blank to disable the beacon.
NEXT_PUBLIC_CF_BEACON=

# Google Search Console verification token (Search Console → Settings →
# Ownership verification → HTML tag → the `content` value). Adds the
# google-site-verification meta tag. Leave blank until you have it.
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# OpenRouter API key for the site AI assistant (https://openrouter.ai/keys).
# Server-side only — never exposed to the browser. In production:
# `wrangler secret put OPENROUTER_API_KEY`.
OPENROUTER_API_KEY=sk-or-v1-...
# Any chat model; a capable free one is recommended (falls back automatically
# if rate-limited). See https://openrouter.ai/models?max_price=0
OPENROUTER_MODEL=openai/gpt-oss-20b:free
